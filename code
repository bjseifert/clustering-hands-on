import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn import datasets
from sklearn.cluster import KMeans, DBSCAN
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import adjusted_rand_score, confusion_matrix

# 1. Load Data
iris = datasets.load_iris()
df = pd.DataFrame(iris.data, columns=iris.feature_names)
y_true = iris.target # True labels for comparison

# 2. Data Exploration
print("Summary Statistics:\n", df.describe())
sns.pairplot(df)
plt.show()

# 3. Preprocessing
scaler = StandardScaler()
X_scaled = scaler.fit_transform(df)

# 4. K-Means Clustering
# Let's use K=3 since we know there are 3 species
kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
km_labels = kmeans.fit_predict(X_scaled)

# 5. DBSCAN Clustering
# eps=0.5 and min_samples=5 are standard starting points
dbscan = DBSCAN(eps=0.5, min_samples=5)
db_labels = dbscan.fit_predict(X_scaled)

# 6. Visualization
fig, (ax1, ax2, ax3) = plt.subplots(1, 3, figsize=(18, 5))

# Plot True Labels
ax1.scatter(X_scaled[:, 0], X_scaled[:, 1], c=y_true, cmap='viridis')
ax1.set_title("Actual Species Labels")

# Plot K-Means
ax2.scatter(X_scaled[:, 0], X_scaled[:, 1], c=km_labels, cmap='magma')
ax2.set_title(f"K-Means (K=3)\nARI Score: {adjusted_rand_score(y_true, km_labels):.2f}")

# Plot DBSCAN
ax3.scatter(X_scaled[:, 0], X_scaled[:, 1], c=db_labels, cmap='coolwarm')
ax3.set_title(f"DBSCAN\nNoise Points: {list(db_labels).count(-1)}")

plt.tight_layout()
plt.show()
